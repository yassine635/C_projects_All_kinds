{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Universal C/C++ Compiler",
      "type": "shell",
      "command": "gcc",
      "args": [
        "${file}",
        "-o",
        "${fileDirname}\\${fileBasenameNoExtension}.exe",
        "-IC:/raylib/include",
        "-IC:/SDL2/include",
        "-LC:/raylib/lib",
        "-LC:/SDL2/lib",
        "-mconsole",
        "-lraylib",
        "-lSDL2main",
        "-lSDL2",
        "-lopengl32",
        "-lgdi32",
        "-lwinmm"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    }
  ]
}